---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import HeroParallax from '../components/HeroParallax';
import Services from '../components/Services.astro';
import PortfolioPreview from '../components/PortfolioPreview';
import Pricing from '../components/Pricing.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import Chatbot from '../components/Chatbot';
import '../styles/hero-parallax.css';
import '../styles/chatbot.css';
import '../styles/portfolio-preview.css';
import '../styles/section-transitions.css';
---

<Layout title="BARAVORAGE | Jasa Perancangan Website Profesional">
    <Navbar />
    <HeroParallax client:load />
    <Services />
    <PortfolioPreview client:visible />
    <Pricing />
    <Contact />
    <Footer />
    <Chatbot client:idle apiKey={import.meta.env.PUBLIC_GROQ_API_KEY} />
</Layout>

<script>
    // Scroll reveal animation for fade-in elements AND section headers
    function revealOnScroll() {
        // Reveal cards
        const elements = document.querySelectorAll('.fade-in');
        elements.forEach((el, index) => {
            const elementTop = el.getBoundingClientRect().top;
            const windowHeight = window.innerHeight;
            if (elementTop < windowHeight - 80) {
                setTimeout(() => {
                    el.classList.add('visible');
                }, (index % 6) * 80);
            }
        });

        // Reveal section headers with parallax
        const headers = document.querySelectorAll('.section-header');
        headers.forEach((header) => {
            const headerTop = header.getBoundingClientRect().top;
            const windowHeight = window.innerHeight;
            if (headerTop < windowHeight - 60) {
                header.classList.add('visible');
            }
        });
    }

    window.addEventListener('scroll', revealOnScroll);
    window.addEventListener('DOMContentLoaded', revealOnScroll);
    revealOnScroll();
</script>
