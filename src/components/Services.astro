---
const services = [
    {
        title: "Website Company Profile",
        desc: "Website profesional untuk menampilkan profil perusahaan, layanan, dan informasi bisnis Anda secara elegan.",
        icon: `<rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line>`
    },
    {
        title: "E-Commerce",
        desc: "Toko online lengkap dengan sistem pembayaran, keranjang belanja, dan manajemen produk yang mudah dikelola.",
        icon: `<circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="m1 1 4 4h14l-2 8H7"></path>`
    },
    {
        title: "Responsive Design",
        desc: "Desain yang optimal di semua perangkat. Tampil sempurna di desktop, tablet, maupun smartphone.",
        icon: `<rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line>`
    },
    {
        title: "Custom Development",
        desc: "Pengembangan fitur khusus sesuai kebutuhan unik bisnis Anda. Dari sistem booking hingga dashboard admin.",
        icon: `<polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline>`
    },
    {
        title: "SEO Optimization",
        desc: "Optimasi mesin pencari agar website Anda mudah ditemukan oleh calon pelanggan di Google dan Bing.",
        icon: `<path d="M12 20V10"></path><path d="M18 20V4"></path><path d="M6 20v-4"></path>`
    },
    {
        title: "Maintenance & Support",
        desc: "Dukungan teknis dan pemeliharaan website berkelanjutan untuk menjaga performa dan keamanan optimal.",
        icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>`
    }
];
---

<section class="services" id="layanan">
    <div class="container">
        <div class="section-header">
            <p class="section-subtitle">Layanan Kami</p>
            <h2 class="section-title">Solusi Digital untuk Bisnis Anda</h2>
            <div class="title-divider"></div>
            <p class="section-desc">Kami menyediakan layanan lengkap dari konsep hingga peluncuran, memastikan website Anda tampil maksimal.</p>
        </div>
        <div class="services-grid">
            {services.map((service, i) => (
                <div class="service-card fade-in">
                    <div class="service-card-inner">
                        <div class="service-icon">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={service.icon} />
                        </div>
                        <div class="service-content">
                            <h3>{service.title}</h3>
                            <p>{service.desc}</p>
                        </div>
                        <div class="service-number">{String(i + 1).padStart(2, '0')}</div>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<style>
    .services {
        padding: 120px 0;
        background: var(--bg);
        position: relative;
    }

    .section-desc {
        font-size: 1rem;
        color: var(--text-light);
        max-width: 560px;
        margin: 0 auto;
        line-height: 1.7;
    }

    .title-divider {
        width: 50px;
        height: 3px;
        background: var(--accent);
        margin: 16px auto 20px;
        border-radius: 3px;
    }

    .services-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 28px;
    }

    .service-card {
        position: relative;
        border-radius: 16px;
        background: var(--bg);
        border: 1px solid var(--border);
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .service-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, var(--accent), var(--accent-light));
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .service-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
        border-color: rgba(249, 115, 22, 0.2);
    }

    .service-card:hover::before {
        transform: scaleX(1);
    }

    .service-card-inner {
        padding: 36px 32px;
        position: relative;
    }

    .service-icon {
        width: 52px;
        height: 52px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #fff7ed, #ffedd5);
        border-radius: 12px;
        color: var(--accent);
        margin-bottom: 24px;
        transition: all 0.3s ease;
    }

    .service-card:hover .service-icon {
        background: var(--accent);
        color: #fff;
        transform: scale(1.05);
    }

    .service-content h3 {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 12px;
        color: var(--primary);
        letter-spacing: -0.2px;
    }

    .service-content p {
        font-size: 0.9rem;
        color: var(--text-light);
        line-height: 1.75;
    }

    .service-number {
        position: absolute;
        top: 28px;
        right: 28px;
        font-size: 2.5rem;
        font-weight: 800;
        color: rgba(249, 115, 22, 0.06);
        line-height: 1;
        pointer-events: none;
        transition: color 0.3s ease;
    }

    .service-card:hover .service-number {
        color: rgba(249, 115, 22, 0.12);
    }

    @media (max-width: 1024px) {
        .services-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 640px) {
        .services {
            padding: 80px 0;
        }

        .services-grid {
            grid-template-columns: 1fr;
            gap: 20px;
        }

        .service-card-inner {
            padding: 28px 24px;
        }
    }
</style>
